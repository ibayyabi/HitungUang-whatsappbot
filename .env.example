# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# WhatsApp Fonnte Bot Config
BOT_NAME=CuanBeres
PORT=3001
FONNTE_TOKEN=your_fonnte_api_token_here
FONNTE_SEND_URL=https://api.fonnte.com/send
FONNTE_COUNTRY_CODE=62
FONNTE_WEBHOOK_PATH=/webhook/fonnte
FONNTE_PUBLIC_WEBHOOK_URL=https://your-public-domain.example/webhook/fonnte
FONNTE_CONNECT_WEBHOOK_PATH=/webhook/fonnte/connect
FONNTE_MESSAGE_STATUS_WEBHOOK_PATH=/webhook/fonnte/message-status
FONNTE_WEBHOOK_SECRET=change_this_optional_secret

# Supabase
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
WEB_APP_URL=http://localhost:3000
AUTH_PROXY_EMAIL_DOMAIN=auth.cuanberes.local
