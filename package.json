{
    "name": "hitung-uang-telegrambot",
    "version": "1.0.0",
    "description": "Telegram bot untuk mencatat transaksi otomatis ke Supabase menggunakan Gemini AI",
    "main": "src/index.js",
    "scripts": {
        "start": "node src/index.js",
        "dev": "nodemon src/index.js",
        "dev:gateway": "node scripts/devGateway.js",
        "test": "jest"
    },
    "keywords": [
        "telegram",
        "bot",
        "expense",
        "tracker",
        "gemini",
        "ai",
        "google-sheets"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@google/generative-ai": "^0.21.0",
        "@supabase/supabase-js": "^2.98.0",
        "dotenv": "^16.4.7",
        "ecdsa-sig-formatter": "^1.0.11",
        "googleapis": "^144.0.0",
        "node-telegram-bot-api": "^0.66.0",
        "winston": "^3.17.0"
    },
    "devDependencies": {
        "jest": "^29.7.0",
        "nodemon": "^3.1.9"
    },
    "jest": {
        "testMatch": [
            "**/src/__tests__/**/*.test.js"
        ],
        "testPathIgnorePatterns": [
            "/node_modules/",
            "/node_modules.bak/",
            "/web/node_modules/"
        ]
    }
}
